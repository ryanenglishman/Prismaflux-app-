# OpenAI — genere les prompts (GPT-4o) et les images (gpt-image-1)
OPENAI_API_KEY=sk-...

# Pinterest — access token de ton app developer (developers.pinterest.com)
PINTEREST_ACCESS_TOKEN=pina_...

# Pinterest — ID numerique du board cible
# Utilise GET /api/marketing/pinterest/boards pour le trouver
PINTEREST_BOARD_ID=

# Vercel Cron — secret pour authentifier les appels cron
# Genere avec: openssl rand -hex 32
CRON_SECRET=

# (Optionnel) Webhook pour notifications email/Slack
# Recoit un POST JSON avec le resultat du pipeline chaque jour
# Exemples : Zapier webhook, Make webhook, n8n webhook, etc.
NOTIFICATION_WEBHOOK_URL=
